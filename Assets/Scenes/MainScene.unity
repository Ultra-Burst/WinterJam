--- !u!114 &2082814821
MonoBehaviour:
  m_ObjectHideFlags: 2
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2082814627}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ec422cd568a9c4a31ad7c36d0572b9da, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  itemId: 167
  indentLevel: 0
  storyText: "As you exhaust all the questions you have for him, you thank him for
    taking the time out of his day to talk to you.{wc}He seems proud and says that
    he appreciates the thank you, and that if you ever want to go out on a date,
    you should contact him through the number on his profile.{wc}You say that you
    will, before telling him that you have to go, and that you\u2019ll message him
    again later.\r\n"
  description: 
  character: {fileID: 0}
  portrait: {fileID: 0}
  voiceOverClip: {fileID: 0}
  showAlways: 1
  showCount: 1
  extendPrevious: 0
  fadeWhenDone: 1
  waitForClick: 1
  stopVoiceover: 1
  waitForVO: 0
  setSayDialog: {fileID: 0}
--- !u!114 &2082814822
MonoBehaviour:
  m_ObjectHideFlags: 2
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2082814627}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ec422cd568a9c4a31ad7c36d0572b9da, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  itemId: 166
  indentLevel: 0
  storyText: "You text a simple \u201Chello!\u201D and greet them with a normal amount
    of enthusiasm.{wc}He messages you back fairly quickly, especially for someone
    who types such lengthy texts\u2026 but he does greet you in return, and asks
    your name.{wc}You tell it to him, before deciding to ask him his name too, especially
    considering that you already told him yours\u2026"
  description: 
  character: {fileID: 0}
  portrait: {fileID: 0}
  voiceOverClip: {fileID: 0}
  showAlways: 1
  showCount: 1
  extendPrevious: 0
  fadeWhenDone: 1
  waitForClick: 1
  stopVoiceover: 1
  waitForVO: 0
  setSayDialog: {fileID: 0}
