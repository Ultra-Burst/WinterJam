--- !u!114 &591099195
MonoBehaviour:
  m_ObjectHideFlags: 2
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 591099011}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ec422cd568a9c4a31ad7c36d0572b9da, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  itemId: 166
  indentLevel: 0
  storyText: "You text a simple \u201Chello!\u201D and greet them with a normal amount
    of enthusiasm. She takes a moment to respond, but she does, and she greets you
    back and asks if you matched with her too.{wc}You respond with a \u201Cyes!\u201D
    and tell her your name, which she says is a very lovely name.{wc}You thank her,
    before thinking that it might be a good idea to ask her name too\u2026 she seems
    very nice, after all."
  description: 
  character: {fileID: 0}
  portrait: {fileID: 0}
  voiceOverClip: {fileID: 0}
