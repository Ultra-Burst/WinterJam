  m_Name: 
  m_EditorClassIdentifier: 
  itemId: 167
  indentLevel: 0
  storyText: "As you exhaust all the questions you have for them, you thank them
    for taking the time out of their day to talk to you. They seem very nonchalant
    about it, and say that talking with you was alright and that they didn\u2019t
    hate it.{wc}You tell them that you have to go and that you\u2019ll message them
    later, and they say it\u2019s alright before suddenly going offline themself.\r\n"
  description: 
  character: {fileID: 0}
  portrait: {fileID: 0}
  voiceOverClip: {fileID: 0}
  showAlways: 1
  showCount: 1
