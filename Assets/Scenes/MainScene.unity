MonoBehaviour:
  m_ObjectHideFlags: 2
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2034115643}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ec422cd568a9c4a31ad7c36d0572b9da, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  itemId: 166
  indentLevel: 0
  storyText: "You text a simple \u201Chello!\u201D and greet them with a normal amount
    of enthusiasm. It takes a while for them to message back, almost 20 minutes\u2026
    but finally, you get a response from them!{wc}They simply responded with a \u201Csup,\u201D,
    but it\u2019s better than nothing, at least!{wc}You tell them your name and that
    you matched with them, and while they don\u2019t seem very talkative, they at
    least give you text responses, unlike all the ghosters you\u2019ve been paired
    with.{wc}Still, you decide to ask their name, and pray that you\u2019ll get a
    semi-quick response too\u2026"
  description: 
  character: {fileID: 0}
  portrait: {fileID: 0}
  voiceOverClip: {fileID: 0}
  showAlways: 1
